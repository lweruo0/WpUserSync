    <string name="PLG_WP_USER_SYNC_TOKEN_NOT_CONFIGURED">Hinweis: Hinterlege einen SHA-256-Hash des API-Tokens in den Plugin-Einstellungen, bevor du den Endpunkt produktiv verwendest.</string>

    <string name="PLG_WP_USER_SYNC_ENABLED">Plugin aktiv</string>
