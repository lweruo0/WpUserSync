    <string name="PLG_WP_USER_SYNC_REQUIRE_HTTPS">HTTPS erzwingen</string>
    <string name="PLG_WP_USER_SYNC_REQUIRE_HTTPS_DESC">Lehnt Requests ohne HTTPS ab.</string>
    <string name="PLG_WP_USER_SYNC_UPDATE_EXISTING_BY_EMAIL">Bestehende Benutzer per E-Mail aktualisieren</string>
